# ═══════════════════════════════════════════════════════════════════════════════
# AgentGRIT 2.0 Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
#
# ⚠️ COST OPTIMIZATION STRATEGY ⚠️
# This system is designed to MINIMIZE expensive API usage.
# Priority order:
#   1. Ollama (FREE, unlimited) - Simple code, explanations, formatting
#   2. Perplexity ($5/month free tier) - Research, web search, docs
#   3. Grok (Premium) - Real-time social, X/Twitter context
#   4. Claude (EXPENSIVE - use sparingly!) - Complex architecture only
#
# Claude should ONLY be called for truly complex tasks that others can't handle.
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────────
# PRIORITY 1: OLLAMA (FREE - Use for most tasks)
# ─────────────────────────────────────────────────────────────────────────────────

# Local Ollama - FREE and UNLIMITED
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3-coder:30b
OLLAMA_ENABLED=true

# Tasks handled by Ollama (FREE):
# - Simple code generation
# - Code formatting and linting help
# - Boilerplate generation
# - Code explanations
# - Basic refactoring

# ─────────────────────────────────────────────────────────────────────────────────
# PRIORITY 2: PERPLEXITY PRO ($5/month free tier)
# ─────────────────────────────────────────────────────────────────────────────────

# Perplexity API - Has web search, great for research
PPLX_API_KEY=pplx-your-key-here
PPLX_MONTHLY_BUDGET=5.00

# Tasks handled by Perplexity:
# - Web research (package registries, changelogs, docs lookups)
# - API documentation
# - Competitor analysis
# - Current events and news
# - Any task requiring web search

# ─────────────────────────────────────────────────────────────────────────────────
# PRIORITY 3: GROK 4.x (xAI API — agentic + real-time X context)
# ─────────────────────────────────────────────────────────────────────────────────

# Grok via xAI - Great for agentic tasks + X/Twitter context Perplexity can't reach
GROK_API_KEY=
XAI_API_KEY=          # alias; used if GROK_API_KEY is unset
GROK_ENABLED=true
# Optionally pin exact model strings without editing code as providers rename:
# GROK_MODEL=grok-beta
# PPLX_MODEL=llama-3.1-sonar-small-128k-online

# Tasks handled by Grok:
# - Real-time social media analysis
# - Real-time social sentiment
# - Community discussion context
# - X/Twitter trend analysis

# ─────────────────────────────────────────────────────────────────────────────────
# PRIORITY 4: ANTHROPIC CLAUDE (EXPENSIVE - Use ONLY when necessary!)
# ─────────────────────────────────────────────────────────────────────────────────

# Claude API - ONLY for complex tasks that other models can't handle
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ⚠️ USAGE TRACKING - Update these to avoid hitting limits
CLAUDE_SESSION_PERCENT=0
CLAUDE_WEEKLY_PERCENT=0
CLAUDE_WEEKLY_RESET_DAY=Monday

# Model Selection (when Claude IS needed)
PRIMARY_MODEL=claude-sonnet-4-20250514
COMPLEX_MODEL=claude-opus-4-5-20250514
SIMPLE_MODEL=claude-haiku-4-5-20250514

# Tasks handled by Claude (ONLY these):
# - Complex system architecture decisions
# - Multi-file refactoring
# - Critical production code
# - Security-sensitive implementations
# - Bylaw governance decisions

# ─────────────────────────────────────────────────────────────────────────────────
# TELEGRAM BOT CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────────

# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Your Telegram user ID (for admin access)
# Get from @userinfobot on Telegram
TELEGRAM_ADMIN_IDS=123456789,987654321

# Optional: Group chat for notifications
TELEGRAM_NOTIFICATION_CHAT_ID=

# ─────────────────────────────────────────────────────────────────────────────────
# DATABASE & CACHE
# ─────────────────────────────────────────────────────────────────────────────────

# SQLite database path
DATABASE_URL=sqlite+aiosqlite:///./data/agentgrit.db

# Redis for caching (optional but recommended)
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true

# ─────────────────────────────────────────────────────────────────────────────────
# API SERVER
# ─────────────────────────────────────────────────────────────────────────────────

# FastAPI server configuration
API_HOST=127.0.0.1  # loopback only; set 0.0.0.0 ONLY behind auth + firewall (see SECURITY.md)
API_PORT=8000
API_RELOAD=false

# API authentication (generate a secure key)
API_SECRET_KEY=your-secret-key-generate-with-openssl-rand-hex-32

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────────
# ─────────────────────────────────────────────────────────────────────────────────


# Web research scraper cache TTL (seconds)

# ─────────────────────────────────────────────────────────────────────────────────
# EXTERNAL-ACTION AGENTS (Optional)
# ─────────────────────────────────────────────────────────────────────────────────



# Execution safety
DRY_RUN=true

# ─────────────────────────────────────────────────────────────────────────────────
# LOGGING & MONITORING
# ─────────────────────────────────────────────────────────────────────────────────

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log output directory
LOG_DIR=./logs

# Structured logging format
LOG_FORMAT=json

# ─────────────────────────────────────────────────────────────────────────────────
# GOVERNANCE SETTINGS
# ─────────────────────────────────────────────────────────────────────────────────

# Trust promotion thresholds
TRUST_PROMOTE_THRESHOLD=5
TRUST_AUTONOMOUS_THRESHOLD=20

# Cost escalation threshold (USD)
COST_ESCALATION_THRESHOLD=1.00

# Digest notification interval (hours)
DIGEST_INTERVAL_HOURS=4

# ─────────────────────────────────────────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────────────────────────────────────────

# Encryption key for secrets storage (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your-32-byte-hex-key-here

# Session timeout (seconds)
SESSION_TIMEOUT=3600

# NOTIFICATIONS (opt-in; see docs/NOTIFICATIONS.md)
# Channels: none | log | telegram | webhook | command
NOTIFY_CHANNEL=none
NOTIFY_TELEGRAM_BOT_TOKEN=
NOTIFY_TELEGRAM_CHAT_ID=
NOTIFY_WEBHOOK_URL=
NOTIFY_COMMAND=

# --- Frontier resilience, competition mode, voice channel ---
PROVIDER_FALLBACK_ON_QUOTA=true
COMPETITION_MODE=false
XAI_VOICE_ENABLED=false
XAI_VOICE_AGENT_URL=
XAI_PHONE_NUMBER=
XAI_API_KEY=

# Log rotation (bounds JSONL exhaust; paired with the gardener)
LOG_MAX_MB=5
LOG_KEEP=3

# Google Custom Search (optional research provider — trust tier 0.72)
# CSE ID: https://cse.google.com  |  API key: https://console.cloud.google.com
# Free: 100 queries/day; paid ~$5 per 1,000 queries.
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=
